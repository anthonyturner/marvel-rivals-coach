{
  "name": "marvel-rivals-coach",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && npm run typecheck:api",
    "vercel:build": "npm run build && npm run sync:glossary:missing -- --vercel-production-only",
    "typecheck:api": "tsc -p tsconfig.api.json --noEmit",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "db:seed": "node scripts/seed-sqlite.mjs",
    "db:sync": "node scripts/sync-external-sources.mjs",
    "sync:home-news": "node --experimental-strip-types scripts/sync-home-news.mjs",
    "sync:glossary": "node scripts/sync-glossary.mjs",
    "sync:glossary:missing": "node scripts/sync-glossary-missing.mjs",
    "sync:glossary:terms": "node scripts/sync-glossary-terms.mjs",
    "sync:heroes": "node scripts/sync-heroes.mjs",
    "sync:hero-archetypes": "node --experimental-strip-types scripts/sync-hero-archetypes.mjs",
    "sync:official-heroes": "node scripts/sync-official-heroes.mjs",
    "sync:official-hero-images": "node scripts/sync-official-hero-images.mjs",
    "check:official-heroes": "node scripts/sync-official-heroes.mjs --check",
    "watch:official-heroes": "node scripts/sync-official-heroes.mjs --watch --interval-days 3",
    "sync:tier-list": "node --experimental-strip-types scripts/sync-tier-list.mjs",
    "sync:game-stats": "node --experimental-strip-types scripts/sync-game-stats.mjs",
    "refresh:counters": "node scripts/refresh-counter-picks.mjs",
    "refresh:playstyles": "node scripts/refresh-playstyles.mjs",
    "refresh:build-profiles": "node scripts/refresh-build-profiles.mjs",
    "content:update": "npm run db:seed && npm run db:sync && npm run sync:home-news && npm run sync:heroes && npm run sync:official-heroes && npm run refresh:counters",
    "serve:ssr:marvel-rivals-coach": "node dist/marvel-rivals-coach/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.24",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.10",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tursodatabase/serverless": "^1.2.3",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.10",
    "@angular/cli": "^20.3.10",
    "@angular/compiler-cli": "^20.3.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.19.43",
    "esbuild": "^0.28.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
