{
  "version": 2,
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "dist/marvel-rivals-coach/browser",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.csr.html"
    }
  ],
  "crons": [
    {
      "path": "/api/sync/home-news",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/sync/tier-list",
      "schedule": "20 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/glossary",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/api/heroes",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/api/tier-list",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
